<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.seblakjeletot.app"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="23"
        android:targetSdkVersion="35" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@drawable/logo_seblak"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo_seblak"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.SeblakJeletotApp" >
        <activity android:name="com.seblakjeletot.app.activity.HistoryActivity" />
        <activity android:name="com.seblakjeletot.app.activity.CheckoutActivity" />
        <activity android:name="com.seblakjeletot.app.activity.CartActivity" />
        <activity android:name="com.seblakjeletot.app.activity.DetailMenuActivity" />
        <activity android:name="com.seblakjeletot.app.activity.MenuActivity" />
        <activity android:name="com.seblakjeletot.app.activity.HomeActivity" />
        <activity
            android:name="com.seblakjeletot.app.activity.SplashActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>