<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/ivDetailMenu"
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:background="@drawable/bg_card"
            android:scaleType="centerCrop"
            android:src="@drawable/seblak_original" />

        <TextView
            android:id="@+id/tvNamaMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Nama Menu"
            android:textColor="@color/primary_red"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDeskripsiMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Deskripsi menu"
            android:textColor="@color/text_soft"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvHargaMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Rp0"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- PILIHAN LEVEL PEDAS UNTUK SEBLAK -->
        <LinearLayout
            android:id="@+id/layoutLevelPedas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Level Pedas"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupLevelPedas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbLevel0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Level 0 - Tidak Pedas"
                    android:textColor="@color/text_dark" />

                <RadioButton
                    android:id="@+id/rbLevel1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level 1 - Sedikit Pedas"
                    android:textColor="@color/text_dark" />

                <RadioButton
                    android:id="@+id/rbLevel2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level 2 - Pedas Ringan"
                    android:textColor="@color/text_dark" />

                <RadioButton
                    android:id="@+id/rbLevel3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level 3 - Pedas"
                    android:textColor="@color/text_dark" />

                <RadioButton
                    android:id="@+id/rbLevel4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level 4 - Sangat Pedas"
                    android:textColor="@color/text_dark" />

                <RadioButton
                    android:id="@+id/rbLevel5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level 5 - Jeletot"
                    android:textColor="@color/text_dark" />

            </RadioGroup>

        </LinearLayout>

        <!-- PILIHAN MINUMAN -->
        <LinearLayout
            android:id="@+id/layoutMinuman"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilihan Minuman"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Suhu Minuman"
                android:textColor="@color/primary_red"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupSuhu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbDingin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Air Dingin"
                    android:textColor="@color/text_dark" />

                <RadioButton
                    android:id="@+id/rbHangat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Air Hangat"
                    android:textColor="@color/text_dark" />

            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Ukuran"
                android:textColor="@color/primary_red"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupUkuran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbKecil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Kecil"
                    android:textColor="@color/text_dark" />

                <RadioButton
                    android:id="@+id/rbSedang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sedang (+Rp2.000)"
                    android:textColor="@color/text_dark" />

                <RadioButton
                    android:id="@+id/rbBesar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Besar (+Rp4.000)"
                    android:textColor="@color/text_dark" />

            </RadioGroup>

            <TextView
                android:id="@+id/tvInfoUkuran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Ukuran kecil menggunakan harga dasar."
                android:textColor="@color/text_soft"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- CATATAN -->
        <EditText
            android:id="@+id/etCatatan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#F5F5F5"
            android:hint="Catatan tambahan, contoh: tanpa sayur / es sedikit"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:padding="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_soft" />

        <!-- JUMLAH -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Jumlah"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnMinus"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_button_secondary"
                android:text="-"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvJumlah"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnPlus"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_button_primary"
                android:text="+"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/btnTambahKeranjang"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:text="Tambah ke Keranjang"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>