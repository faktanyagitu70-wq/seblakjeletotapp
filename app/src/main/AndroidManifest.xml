<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@drawable/logo_seblak"
        android:roundIcon="@drawable/logo_seblak"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SeblakJeletotApp">

        <activity android:name=".activity.HistoryActivity" />
        <activity android:name=".activity.CheckoutActivity" />
        <activity android:name=".activity.CartActivity" />
        <activity android:name=".activity.DetailMenuActivity" />
        <activity android:name=".activity.MenuActivity" />
