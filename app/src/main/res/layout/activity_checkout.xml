<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checkout"
            android:textColor="@color/primary_red"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Lengkapi data pelanggan, pengambilan, pembayaran, dan pengantaran."
            android:textColor="@color/text_soft"
            android:textSize="14sp" />

        <!-- DATA PELANGGAN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Data Pelanggan"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNamaCustomer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="#F5F5F5"
                android:hint="Nama pelanggan"
                android:inputType="textPersonName"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_soft" />

            <EditText
                android:id="@+id/etNoHp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="#F5F5F5"
                android:hint="Nomor WhatsApp"
                android:inputType="phone"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_soft" />

        </LinearLayout>

        <!-- METODE PENGAMBILAN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Metode Pengambilan"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupPengambilan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbAmbilTempat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Ambil di Tempat"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rbAntar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diantar"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp" />

            </RadioGroup>

            <EditText
                android:id="@+id/etAlamat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#F5F5F5"
                android:hint="Alamat pengiriman"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:padding="14dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_soft"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutKurirPengantaran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="#F5F5F5"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Layanan Pengantaran"
                    android:textColor="@color/primary_red"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/radioGroupKurir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbGrab"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="Grab"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbGojek"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gojek"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbShopeeFood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ShopeeFood"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbKurirPenjual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kurir Penjual"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp" />

                </RadioGroup>

                <TextView
                    android:id="@+id/tvInfoKurir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Pesanan akan dikirim menggunakan Grab. Ongkir mengikuti aplikasi Grab."
                    android:textColor="@color/text_soft"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- METODE PEMBAYARAN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Metode Pembayaran"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupPembayaran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbBayarTempat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Bayar di Tempat"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rbTransfer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transfer Bank"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rbQris"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QRIS"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp" />

            </RadioGroup>

            <LinearLayout
                android:id="@+id/layoutInfoPembayaran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="#F5F5F5"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvJudulInfoPembayaran"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bayar di Tempat"
                    android:textColor="@color/primary_red"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvInfoPembayaran"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Pembayaran dilakukan saat pesanan diambil atau diterima."
                    android:textColor="@color/text_dark"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvCatatanPembayaran"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Siapkan uang tunai sesuai total pesanan."
                    android:textColor="@color/text_soft"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/ivQris"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="14dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/qris_seblak"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- RINGKASAN PESANAN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ringkasan Pesanan"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRingkasanPesanan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#F5F5F5"
                android:padding="14dp"
                android:text="Ringkasan pesanan"
                android:textColor="@color/text_dark"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Total Bayar"
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTotalBayar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Rp0"
                android:textColor="@color/primary_red"
                android:textSize="26sp"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/btnBuatPesanan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:text="Buat Pesanan"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>